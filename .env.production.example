# Cloudflare Tunnel backend
DATABASE_URL=sqlite+aiosqlite:////app/data/quantbot.db
ADMIN_TOKEN=replace-with-a-long-random-token
CORS_ORIGINS=https://your-vercel-app.vercel.app,https://your-domain.com
AUTO_CREATE_TABLES=false
SEED_UNIVERSE_ON_STARTUP=true
SCHEDULER_ENABLED=true
COLLECT_CRON_HOUR=22
COLLECT_CRON_MINUTE=0
SCHEDULER_COLLECT_PRICES=false
SCHEDULER_LOOKBACK_DAYS=365
SCHEDULER_CATCH_UP_ON_STARTUP=true
SCHEDULER_STALE_AFTER_DAYS=1
HOLDINGS_HTTP_TIMEOUT=30
SIGNAL_MIN_AUM=100000000
SIGNAL_EXCHANGES=NASDAQ,NasdaqGS,NasdaqGM,NasdaqCM,NMS,NGM,NCM,NYSE,NYQ,NYSEArca,NYSE Arca,PCX,Cboe US,Cboe BZX,BATS,BTS,NYSE American,ASE
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token
# Cloudflare Zero Trust public hostname:
# api.your-domain.com -> http://api:8000

# Vercel frontend
NEXT_PUBLIC_API_BASE_URL=https://api.your-domain.com
