# Oracle backend
DATABASE_URL=sqlite+aiosqlite:////app/data/quantbot.db
ADMIN_TOKEN=replace-with-a-long-random-token
CORS_ORIGINS=https://your-vercel-app.vercel.app,https://your-domain.com
AUTO_CREATE_TABLES=false
SEED_UNIVERSE_ON_STARTUP=true
SCHEDULER_ENABLED=true
COLLECT_CRON_HOUR=22
COLLECT_CRON_MINUTE=0
SCHEDULER_COLLECT_PRICES=false
SCHEDULER_LOOKBACK_DAYS=365
HOLDINGS_HTTP_TIMEOUT=30
# 공개 노출은 Cloudflare Tunnel(cloudflared, compose 외부)이 처리.
# 터널이 호스트 127.0.0.1:8000 → api 컨테이너로 연결한다.

# Vercel frontend
NEXT_PUBLIC_API_BASE_URL=https://api.your-domain.com
